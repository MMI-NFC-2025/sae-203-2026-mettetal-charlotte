---
import PbImage from "../components/PbImage.astro";
const Scene = Astro.props.scene;
console.log(Scene);
---

<a href={`/scenes/${Scene.id}`}>
    <div
        style="background-color: var(--color-vert); margin: 10px; padding: 5px; border-radius: 15px; box-sizing: border-box;"
    >
        <h3 class="text-center">{Scene.nom_scene}</h3>
        <PbImage
            record={Scene}
            recordImage={Scene?.image?.[0] || Scene?.photo || ""}
            width={400}
            heigth={300}
        />
        <p class="p-2">{Scene.description}</p>
    </div> 
</a>
